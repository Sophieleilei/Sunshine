# ---- Network (Testnet ONLY) ----
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233

# ---- Accounts (run `npm run setup` to faucet-fund + print these) ----
AGENT_SEED=
ALICE_SEED=
MM_SEED=
BANK_SEED=
STABLE_ISSUER_SEED=

# ---- Bridge = native XRP (no issuer, no trustline, no faucet) ----
# RLUSD/stablecoin stays a mainnet option; the demo bridges through XRP (ODL-style).

# ---- Target currency token (issued by the BANK/gateway) ----
DEST_CURRENCY=MXN
# DEST_ISSUER=             # defaults to BANK_SEED's address

# ---- FX + invoice ----
XRP_RATE=10                # target units per 1 XRP (1 XRP = ~10 MXN)
INVOICE_AMOUNT=50          # invoice denominated in target currency (MXN)
INVOICE_SRC_CURRENCY=MXN
INVOICE_DUE_DAYS=7

# ---- Safety / guards ----
MAX_SLIPPAGE=0.1           # wider, to absorb AMM fee + price impact on a small pool
HUMAN_CONFIRM_PAYOUT=false
